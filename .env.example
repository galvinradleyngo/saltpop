# ─────────────────────────────────────────────
#  Audio / Video provider  (choose ONE block)
# ─────────────────────────────────────────────

# Option A – LiveKit (recommended, free cloud tier available)
# Sign up at https://cloud.livekit.io
REACT_APP_LIVEKIT_ENDPOINT=https://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_SECRET_KEY=your_livekit_secret_key

# Option B – Twilio (comment out Option A and uncomment below)
# Sign up at https://www.twilio.com
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_API_KEY_SID=your_twilio_api_key_sid
# TWILIO_API_KEY_SECRET=your_twilio_api_key_secret

# ─────────────────────────────────────────────
#  Database  (SQLite, stored in the volume)
# NOTE: connection_limit=1 is required! SQLite only allows one writer at a time;
# limiting the connection pool to 1 prevents "database is locked" errors.
# ─────────────────────────────────────────────
DATABASE_URL=file:/data/db.sqlite?connection_limit=1
UNICORN_DATABASE_URL=/data/unicorn.sqlite

# ─────────────────────────────────────────────
#  File storage  (local filesystem by default)
# ─────────────────────────────────────────────
USER_FILES_DIRECTORY=/data/user-files
WALLPAPERS_DIRECTORY=/data/wallpapers

# ─────────────────────────────────────────────
#  Public URL
# Set this to the URL your users will open in their browser.
# Use http://localhost:8889 for local testing.
# For production, use the full public address, e.g.:
#   https://saltpop.yourdomain.com
# ─────────────────────────────────────────────
PUBLIC_URL=http://localhost:8889

# ─────────────────────────────────────────────
#  TLS  (optional – terminate TLS here instead of at a load balancer)
# Mount your cert/key files into the container and set these paths.
# ─────────────────────────────────────────────
# SSL_PRIVATE_KEY_PATH=/certs/privkey.pem
# SSL_CERTIFICATE_PATH=/certs/fullchain.pem

# ─────────────────────────────────────────────
#  S3 / file storage  (optional)
# Leave unset to use the local filesystem (Docker volume).
# ─────────────────────────────────────────────
# WALLPAPER_FILES_BUCKET_NAME=my-saltpop-wallpapers
# WALLPAPER_FILES_ORIGIN=https://cdn.yourdomain.com
# USER_FILES_BUCKET_NAME=my-saltpop-user-files
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
